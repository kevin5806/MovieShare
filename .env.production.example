# Image source
MOVIESHARE_IMAGE=ghcr.io/your-github-owner/movieshare:1.0.0

# PostgreSQL
POSTGRES_DB=movieshare
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql://postgres:change-this-postgres-password@postgres:5432/movieshare?schema=public

# Public app URLs
BETTER_AUTH_URL=https://movieshare.example.com
NEXT_PUBLIC_BETTER_AUTH_URL=https://movieshare.example.com

# Security
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Optional integrations
TMDB_API_TOKEN=
TMDB_API_KEY=
TMDB_LANGUAGE=en-US
SEED_ADMIN_EMAIL=admin@movieshare.local
SEED_ADMIN_NAME=movieshare admin
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=movieshare <noreply@movieshare.local>
PUSH_NOTIFICATIONS_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
AUTH_EMAIL_CODE_ENABLED=false
AUTH_MAGIC_LINK_ENABLED=false
AUTH_PASSKEY_ENABLED=false
AUTH_TWO_FACTOR_ENABLED=false

# Media storage and public image delivery
MINIO_ROOT_USER=movieshare
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_CONSOLE_PORT=9001
MEDIA_CDN_PORT=3080
STORAGE_ENDPOINT=http://minio:9000
STORAGE_PUBLIC_BASE_URL=https://media.example.com/movieshare-media
STORAGE_BUCKET=movieshare-media
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=movieshare
STORAGE_SECRET_KEY=change-this-minio-password
STORAGE_FORCE_PATH_STYLE=true
VIXSRC_BASE_URL=
VIXSRC_LANG=en
PLEX_WATCH_URL_TEMPLATE=
STREAMING_VIXSRC_ENABLED=false
STREAMING_PLEX_ENABLED=false
STREAMING_ACTIVE_PROVIDER=
